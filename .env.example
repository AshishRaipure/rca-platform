# ---------------------------------------------------------------------------
# Example environment configuration.
#
#   cp .env.example .env      # then fill in REAL values in .env
#
# .env is git-ignored and MUST NOT be committed. This .example file is the only
# env file that belongs in the repo, and it must contain placeholders only.
#
# For QA / production, do NOT ship a .env at all. Inject these as runtime secrets:
#   - AWS: Secrets Manager or SSM Parameter Store (Kubernetes: External Secrets / sealed secrets)
#   - AWS access for Bedrock + read-only cross-account: use an IAM ROLE (IRSA on EKS, instance
#     profile on EC2). The app uses the default boto3 credential chain, so NO AWS access keys
#     belong here.
#   - Connector tokens must be READ-ONLY and least-privilege; rotate them regularly.
# ---------------------------------------------------------------------------

# --- application ---
APP_ENV=development                       # development | production

# --- database (the app uses the async DSN) ---
DATABASE_DSN=postgresql+asyncpg://rca_app:CHANGE_ME@localhost:5432/rca
# For the psql migration step only, use a normal libpq URL (not committed, your shell):
#   postgresql://rca_app:CHANGE_ME@localhost:5432/rca

# --- OIDC / JWT (your enterprise IdP) ---
OIDC_ISSUER=https://idp.example.com/
OIDC_AUDIENCE=rca-platform-api
OIDC_JWKS_URL=https://idp.example.com/.well-known/jwks.json
# Optional claim-name overrides (defaults shown):
OIDC_ROLES_CLAIM=roles
OIDC_TEAMS_CLAIM=team_ids
OIDC_SERVICES_CLAIM=service_ids

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
# Override the placeholder model ids in libs/llm with your deployment's model ids or
# inference-profile ARNs (the ONLY place model strings live):
BEDROCK_MODEL_FAST=anthropic.claude-haiku-4-5
BEDROCK_MODEL_MID=anthropic.claude-sonnet-4-6
BEDROCK_MODEL_TOP=anthropic.claude-opus-4
BEDROCK_MODEL_VERSION_LABEL=                     # optional; recorded on responses for audit

# --- read-only connector credentials (used by the MCP connectors) ---
# PagerDuty: a READ-ONLY API token
PAGERDUTY_READONLY_API_TOKEN=CHANGE_ME

# ServiceNow: instance URL + a READ-ONLY OAuth bearer token
SERVICENOW_INSTANCE_URL=https://yourinstance.service-now.com
SERVICENOW_READONLY_TOKEN=CHANGE_ME

# Confluence (Cloud): base URL + account email + API token (read-only)
CONFLUENCE_BASE_URL=https://yourorg.atlassian.net/wiki
CONFLUENCE_EMAIL=svc-rca@example.com
CONFLUENCE_API_TOKEN=CHANGE_ME

# --- API behavior (optional) ---
CORS_ORIGINS=                                    # comma-separated; empty = none
